# Commodity Curve Factors — Required API Keys
# Copy this file to .env and fill in your keys.
# .env is git-ignored and will never be committed.

# EIA (Energy Information Administration) — crude, gas, product inventories
# Get a free key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# FRED (Federal Reserve Economic Data) — USD index, yields, inflation
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Nasdaq Data Link — back-month futures (CHRIS dataset), CFTC COT
# Get a free key at: https://data.nasdaq.com/sign-up
NASDAQ_DATA_LINK_API_KEY=
