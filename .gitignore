# Data (downloaded via pipeline)
/data/raw/*
/data/processed/*
/data/cache/*
!/data/raw/.gitkeep
!/data/processed/.gitkeep
!/data/cache/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Environment
venv/
.venv/
.env
.env.local

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
.cursor/

# Claude (local development context)
.claude/

# Generated outputs (reproducible via `make figures`)
/results/figures/
/results/tables/
/results/tearsheets/
/website/assets/figures/
/website/js/chart_data_inline.js

# API keys (NEVER commit)
secrets.yaml
